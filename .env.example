# Copy to .env and fill in for federation. Leave GRID_* unset for standalone play.

WORLD_NAME=Ferrite Wastes
# Public WebSocket URL advertised to the Grid registry (travel handoff).
WORLD_URL=wss://ferrite.skyphusion.org/ws

# Grid Hub HTTP RPC (same GRID_RPC_TOKEN as wrangler secret on grid-hub).
GRID_HUB_URL=https://grid-hub.skyphusion.org/rpc
GRID_HUB_TOKEN=

# Optional overrides (defaults match compose.yaml)
# LISTEN_ADDR=0.0.0.0:8792
# DATA_DIR=/data
# ADMINS=skyphusion
